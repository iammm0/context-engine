# ========== 应用配置（必填） ==========
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here
API_HOST=0.0.0.0
API_PORT=8000

# ========== MongoDB（必填） ==========
# 方式一：使用完整 URI（推荐）
# 无认证（本地未开启 auth）：mongodb://localhost:27017/advanced_rag
# 有认证（开启 auth 后必须）：mongodb://用户名:密码@localhost:27017/advanced_rag?authSource=admin
MONGODB_URI=mongodb://localhost:27017/advanced_rag
MONGODB_DB_NAME=advanced_rag

# 方式二：不设 MONGODB_URI 时，用下面变量拼接
# MONGODB_HOST=localhost
# MONGODB_PORT=27017
# MONGODB_USERNAME=        # 开启认证时必填
# MONGODB_PASSWORD=        # 开启认证时必填
# MONGODB_AUTH_SOURCE=admin

# ========== Neo4j（可选，用于网络图谱等） ==========
# 密码需与 Neo4j 服务端一致。Neo4j 5.x 不允许密码为 neo4j，若用本仓库 docker-compose 启动则填 neo4j123
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123

# ========== Redis（可选，用于缓存） ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ========== Celery 长任务队列（文档处理） ==========
DOCUMENT_TASK_BACKEND=celery
DOCUMENT_TASK_FALLBACK_LOCAL=true
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true

# ========== Qdrant（向量库，可选） ==========
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ========== Ollama（本地模型） ==========
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_ANALYSIS_MODEL=qwen2.5:3b
# FORMULA_MODEL=gemma3:27b
# KNOWLEDGE_MODEL=gemma3:1b

# ========== 文件上传 ==========
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=./uploads

# ========== 日志 ==========
LOG_LEVEL=INFO
LOG_FILE=./logs/advanced-rag-api.log
